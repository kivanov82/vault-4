ANTHROPIC_API_KEY=your-anthropic-api-key
WALLET=0xYourAddress
WALLET_PK=0xYourPrivateKey
VAULT4FUND_ADDRESS=0xb6099d4545156f8ACA1A8Ea7CAA0762D81697809
HYPEREVM_RPC_URL=https://rpc.hyperliquid.xyz/evm

# Trace persistence (Cloud SQL Postgres). Leave unset to disable.
# Local dev (TCP): postgresql://user:pass@localhost:5432/vault4
# Cloud Run (socket): postgresql://vault4_app:PASSWORD@/vault4?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=
CLOUD_SQL_CONNECTION_NAME=
LEDGER_SYNC_INTERVAL_MS=300000

# X (Twitter) posting. Scheduler fires daily with ±10h jitter (14-34h delays).
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_POST_ENABLED=true
X_POST_MIN_HOURS=14
X_POST_MAX_HOURS=34

# CryptoPanic news fetch — optional. When set, the X post mix includes a
# `news_react` content type that comments on recent Hyperliquid / Lighter /
# perps headlines. Without the token, the news topic is silently skipped.
CRYPTOPANIC_API_TOKEN=
