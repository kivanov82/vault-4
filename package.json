{
  "name": "vault-4",
  "version": "1.0.0",
  "private": true,
  "description": "Vault-4 monorepo — automated trading platform",
  "scripts": {
    "dev:api": "cd packages/api && npm run dev",
    "dev:web": "cd packages/web && pnpm dev",
    "build:api": "cd packages/api && npm run docker-build",
    "build:web": "cd packages/web && pnpm build",
    "start:api": "cd packages/api && npm start",
    "start:web": "cd packages/web && pnpm start",
    "build:contracts": "cd packages/contracts && forge build",
    "test:contracts": "cd packages/contracts && forge test -vvv"
  }
}
